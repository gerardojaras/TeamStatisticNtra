@page "/search"
@page "/"
@using TeamSearch.Client.Services
@using TeamSearch.Shared.Dtos
@inject ITeamRecordClient TeamClient

<h3>Team Records Search</h3>

<div style="display:flex;flex-direction:column;gap:12px;max-width:900px;">
    <FluentTextField Label="Search"
                     Value="@SearchText"
                     ValueChanged="OnSearchValueChanged"
                     Placeholder="Enter search text (e.g. Ohio or Scarlet Knights)"/>

    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:end;">
        <FluentSelect TOption="KeyValuePair<string, string>"
                      Label="Sort by"
                      Items="SortByOptions"
                      OptionText="@(o => o.Value)"
                      OptionValue="@(o => o.Key)"
                      SelectedOption="SortBySelectedOption"
                      SelectedOptionChanged="OnSortBySelectedOptionChanged" />
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:end;">

        <FluentSelect TOption="string" Label="Direction" Value="@SortDir" ValueChanged="OnSortDirChanged">
            <FluentOption TOption="string" Value="asc">Ascending</FluentOption>
            <FluentOption TOption="string" Value="desc">Descending</FluentOption>
        </FluentSelect>
    </div>

    <div style="display:flex;gap:10px;">
        <FluentButton Appearance="Appearance.Accent" @onclick="() => PerformSearch()">Search</FluentButton>
        <FluentButton Appearance="Appearance.Neutral" @onclick="Clear">Clear</FluentButton>
    </div>
</div>

@if (IsLoading)
{
    <div style="margin-top:12px;">Loading...</div>
}
else if (ErrorMessage is not null)
{
    <div style="margin-top:12px;color:#b42318;">@ErrorMessage</div>
}
else
{
    <div style="margin-top:14px;">
        <FluentDataGrid TItem="TeamRecordDto"
                        Items="@Results.AsQueryable()"
                        Pageable="false"
                        RefreshItems="OnGridRefreshAsync">
            @foreach (var key in VisibleColumnKeys)
            {
                var colKey = key; // capture for closure
                <TemplateColumn Title="@_allColumns[colKey]"
                                SortBy="@GetSortExpression(colKey)">
                    @GetColumnString(context, colKey)
                </TemplateColumn>
            }
        </FluentDataGrid>
    </div>
}

@code {
    private CancellationTokenSource? _debounceCts;

    private string? SearchText { get; set; }
    private int Page { get; set; } = 1;
    private int PageSize { get; } = 20;

    private string? SortBy { get; set; }
    private string SortDir { get; set; } = "asc";

    private static readonly string[] DefaultSelectedColumns =
        ["Id", "Team", "Mascot", "Wins", "WinningPercentage", "CreatedAt"];

    private readonly Dictionary<string, string> _allColumns = new()
    {
        ["Id"] = "ID",
        ["Rank"] = "Rank",
        ["Team"] = "Team",
        ["Mascot"] = "Mascot",
        ["DateOfLastWin"] = "Date of Last Win",
        ["WinningPercentage"] = "Winning %",
        ["Wins"] = "Wins",
        ["Losses"] = "Losses",
        ["Ties"] = "Ties",
        ["Games"] = "Games",
        ["CreatedAt"] = "Created At"
    };

    private HashSet<string> SelectedColumns { get; set; } = new();

    private List<KeyValuePair<string, string>> SortByOptions { get; set; } = new();
    private KeyValuePair<string, string> SortBySelectedOption { get; set; }

    private List<TeamRecordDto> Results { get; set; } = [];
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    protected override void OnInitialized()
    {
        SelectedColumns = new HashSet<string>(DefaultSelectedColumns);
        SortByOptions = new List<KeyValuePair<string, string>>
        {
            new(string.Empty, "(none)")
        };
        SortByOptions.AddRange(_allColumns);
        SortBySelectedOption = SortByOptions.First();
    }

    IEnumerable<string> VisibleColumnKeys => _allColumns.Keys.Where(c => SelectedColumns.Contains(c));

    private Task OnSearchValueChanged(string? value)
    {
        var e = new ChangeEventArgs { Value = value };
        return OnSearchInput(e);
    }

    private async Task OnSortBySelectedOptionChanged(KeyValuePair<string, string> selected)
    {
        SortBySelectedOption = selected;
        SortBy = string.IsNullOrWhiteSpace(selected.Key) ? null : selected.Key;
        Page = 1;
        await PerformSearch();
    }

    private async Task OnSortDirChanged(string? value)
    {
        SortDir = value is "desc" ? "desc" : "asc";
        Page = 1;
        await PerformSearch();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString();
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(300, token);
            if (!token.IsCancellationRequested)
            {
                Page = 1;
                await PerformSearch(token);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    string GetColumnString(TeamRecordDto r, string col)
    {
        return col switch
        {
            "Id" => r.Id.ToString(),
            "Rank" => r.Rank?.ToString() ?? string.Empty,
            "Team" => r.Team,
            "Mascot" => r.Mascot ?? string.Empty,
            "DateOfLastWin" => r.DateOfLastWin?.ToString("yyyy-MM-dd") ?? string.Empty,
            "WinningPercentage" => r.WinningPercentage?.ToString() ?? string.Empty,
            "Wins" => r.Wins?.ToString() ?? string.Empty,
            "Losses" => r.Losses?.ToString() ?? string.Empty,
            "Ties" => r.Ties?.ToString() ?? string.Empty,
            "Games" => r.Games?.ToString() ?? string.Empty,
            "CreatedAt" => r.CreatedAt.ToString("yyyy-MM-dd"),
            _ => string.Empty
        };
    }

    private GridSort<TeamRecordDto>? GetSortExpression(string col)
    {
        return col switch
        {
            "Id" => GridSort<TeamRecordDto>.ByAscending(x => x.Id),
            "Rank" => GridSort<TeamRecordDto>.ByAscending(x => x.Rank),
            "Team" => GridSort<TeamRecordDto>.ByAscending(x => x.Team),
            "Mascot" => GridSort<TeamRecordDto>.ByAscending(x => x.Mascot),
            "DateOfLastWin" => GridSort<TeamRecordDto>.ByAscending(x => x.DateOfLastWin),
            "WinningPercentage" => GridSort<TeamRecordDto>.ByAscending(x => x.WinningPercentage),
            "Wins" => GridSort<TeamRecordDto>.ByAscending(x => x.Wins),
            "Losses" => GridSort<TeamRecordDto>.ByAscending(x => x.Losses),
            "Ties" => GridSort<TeamRecordDto>.ByAscending(x => x.Ties),
            "Games" => GridSort<TeamRecordDto>.ByAscending(x => x.Games),
            "CreatedAt" => GridSort<TeamRecordDto>.ByAscending(x => x.CreatedAt),
            _ => null
        };
    }

    private async Task OnGridRefreshAsync(GridItemsProviderRequest<TeamRecordDto> request)
    {
        var sorted = request.GetSortByProperties().FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(sorted.PropertyName))
        {
            SortBy = sorted.PropertyName;
            SortDir = sorted.Direction == SortDirection.Descending ? "desc" : "asc";

            var matched = SortByOptions.FirstOrDefault(o => o.Key == SortBy);
            if (!string.IsNullOrWhiteSpace(matched.Key) || SortBy == string.Empty)
            {
                SortBySelectedOption = matched;
            }
        }

        if (request.Count is > 0)
        {
            Page = request.StartIndex / request.Count.Value + 1;
        }

        await PerformSearch(request.CancellationToken);
    }

    async Task PerformSearch(CancellationToken cancellationToken = default)
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            var fields = string.Join(',', SelectedColumns);
            var apiResp = await TeamClient.ListAsync(SearchText, fields, Page, PageSize, SortBy, SortDir, cancellationToken);
            if (!apiResp.Success)
            {
                ErrorMessage = apiResp.Error?.Message ?? "Unknown error";
                Results = [];
            }
            else
            {
                Results = apiResp.Data ?? [];
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Results = [];
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Clear()
    {
        SearchText = string.Empty;
        Page = 1;
        SelectedColumns = new HashSet<string>(DefaultSelectedColumns);
        SortBy = null;
        SortDir = "asc";
        SortBySelectedOption = SortByOptions.FirstOrDefault();
        Results = [];
    }


}
